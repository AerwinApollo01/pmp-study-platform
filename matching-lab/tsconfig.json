{
  "compilerOptions": {
    "target": "ES2019",
    "module": "ES2015",
    "moduleResolution": "node",
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "noImplicitAny": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "exactOptionalPropertyTypes": false,
    "lib": ["ES2019", "DOM", "DOM.Iterable"],
    "sourceMap": false,
    "declaration": false
  },
  "include": ["src/**/*.ts"]
}
